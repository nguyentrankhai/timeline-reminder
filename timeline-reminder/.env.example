GOOGLE_DRIVE_CSV_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
