# === Google Drive ===
# URL chia sẻ từ Google Sheets
GOOGLE_DRIVE_CSV_URL=https://docs.google.com/spreadsheets/d/.../edit

# Service Account (dùng khi file bị giới hạn truy cập)
# Cách 1: đường dẫn đến file JSON key
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account-key.json
# Cách 2: nội dung JSON key (thay thế dấu " bằng \")
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account",...}

# File cục bộ (dùng cho phát triển, không cần Google Drive)
# LOCAL_CSV_PATH=../Timeline Logistics - Timeline.csv

# === SMTP ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# === Notification ===
NOTIFICATION_EMAILS=recipient1@example.com,recipient2@example.com

# === Schedule ===
# Cron expression (mặc định: 15 2 * * * = 09:15 GMT+7)
# CRON_SCHEDULE=15 2 * * *

# === Timezone ===
TZ=Asia/Ho_Chi_Minh

# === Logging ===
# LOG_LEVEL=DEBUG
